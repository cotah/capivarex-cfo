# CFO Agent — variaveis de ambiente (copie para .env e preencha)
# NUNCA commitar o .env com valores reais.

# Supabase "Cerebro Compartilhado" (projeto bybocxguyoejfdhlszpo)
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_KEY=coloque-aqui-a-service-role-key

# Webhook da conta Stripe "Factory" (Developers > Webhooks > Signing secret)
STRIPE_WEBHOOK_SECRET=whsec_coloque-aqui

# Chave exclusiva deste servico (gere uma nova, nao reaproveite de outro servico)
# Sugestao: python -c "import secrets; print(secrets.token_urlsafe(32))"
CFO_API_KEY=gere-uma-chave-nova-exclusiva

# Observabilidade (Sentry) — DSN do projeto (org capivarex-real).
# Vazio = Sentry desligado (no-op).
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
# ENVIRONMENT identifica o ambiente no Sentry (ex: production).
ENVIRONMENT=production

# --- ATLAS (CFO de IA) ---
# Pelo menos uma chave para o ATLAS funcionar (senao /atlas/* = 503).
# Principal = Anthropic (Claude); fallback = OpenAI.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Modelos (opcional; ja tem default no codigo)
ATLAS_ANTHROPIC_MODEL=claude-sonnet-4-6
ATLAS_OPENAI_MODEL=gpt-5.5

# --- Split PADRAO (fallback global) ---
# Aplica esta divisao a QUALQUER receita sem regra especifica de produto.
# Vazio = desligado (receita sem regra vira pending_classification).
# Devem somar 100. Ex.: empresa 75 / pro-labore 25.
DEFAULT_SPLIT_COMPANY_PCT=75
DEFAULT_SPLIT_PRO_LABORE_PCT=25
# Limite (EUR) que o ATLAS aprova sozinho; acima disso, escala pro fundador.
ATLAS_AUTO_APPROVE_LIMIT_EUR=50
